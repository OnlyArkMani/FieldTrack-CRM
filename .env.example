# FieldTrack environment — copy to .env and fill in real values.
# NEVER commit .env. Generate secrets with:  openssl rand -hex 32

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production
APP_NAME=FieldTrack
DEBUG=true                         # MUST be false in production
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Comma-separated. Add the admin dashboard's real origin in production.

# ── Database (Postgres 15 + PostGIS) ────────────────────────────
POSTGRES_USER=fieldtrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=fieldtrack
POSTGRES_HOST_PORT=5433            # host-side port; 5433 avoids your existing dockerized PG
# Used by the app INSIDE compose (overridden in docker-compose.yml).
# For running alembic/app from the host, point at 127.0.0.1:5433:
DATABASE_URL=postgresql+asyncpg://fieldtrack:CHANGE_ME_strong_password@127.0.0.1:5433/fieldtrack
DB_POOL_SIZE=10                    # raise to ~20 at 100 employees; nothing else changes
DB_MAX_OVERFLOW=5

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_HOST_PORT=6380
REDIS_URL=redis://:CHANGE_ME_redis_password@127.0.0.1:6380/0

# ── JWT ──────────────────────────────────────────────────────────
# Two DIFFERENT secrets so a leaked access-token key can't mint refresh tokens.
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32_different
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase Cloud Messaging ─────────────────────────────────────
# Path to the service-account JSON (FCM HTTP v1 API — legacy server keys are deprecated).
FCM_SERVICE_ACCOUNT_FILE=/run/secrets/fcm-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ── Nginx ────────────────────────────────────────────────────────
NGINX_HTTP_PORT=8090               # 8080/8081 unavailable on this machine

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120          # default per-user per-endpoint window

# ── Reports (CSV/Excel/PDF exports) ──────────────────────────────
# Where generated export files are written. In Docker this is a named volume
# (reports_data) owned by the non-root app user. Files + their Redis status
# expire after REPORT_RETENTION_MINUTES.
REPORT_STORAGE_DIR=/srv/fieldtrack/reports
REPORT_RETENTION_MINUTES=60

# ── App server ───────────────────────────────────────────────────
UVICORN_WORKERS=2                  # = vCPU count; raise with bigger VPS
